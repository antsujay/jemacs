{
  "name": "@jemacs/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Jemacs display-agnostic kernel and display layer (re-exports from monorepo root).",
  "exports": {
    ".": "./index.ts",
    "./display/*": "./display/*",
    "./kernel/*": "./kernel/*",
    "./modes/*": "./modes/*",
    "./runtime/*": "./runtime/*",
    "./platform/*": "./platform/*",
    "./lsp/*": "./lsp/*"
  }
}
